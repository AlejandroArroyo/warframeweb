# Database (Neon PostgreSQL - serverless)
DATABASE_URL="postgresql://user:password@ep-example.us-east-2.aws.neon.tech/warframeweb?sslmode=require"

# Redis (Upstash)
REDIS_URL="rediss://default:password@us1-adequate-ape-12345.upstash.io:6379"

# Server
PORT=3001
HOST="0.0.0.0"
NODE_ENV="development"

# CORS
CORS_ORIGIN="http://localhost:5173"

# JWT (cambiar en producción)
# JWT_SECRET="my-super-secret-key"

# Discord OAuth (opcional en dev, necesario en prod)
# DISCORD_CLIENT_ID="your-discord-client-id"
# DISCORD_CLIENT_SECRET="your-discord-client-secret"
# DISCORD_REDIRECT_URI="http://localhost:3001/api/auth/discord/callback"
